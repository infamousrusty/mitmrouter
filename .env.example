# MITMRouter — Environment Variables Template
# ---------------------------------------------------------------------------
# Copy this file to .env and populate the values before running mitmrouter.
# The .env file is listed in .gitignore and must NEVER be committed.
#
# Usage:
#   cp .env.example .env
#   $EDITOR .env
#   source .env  (or use direnv)
# ---------------------------------------------------------------------------

# Wi-Fi access point password (required for wifi_ap and hybrid modes)
MITMROUTER_WIFI_PASSWORD=change_me_before_use

# Optional: override the SSID for the pentest profile
MITMROUTER_PENTEST_SSID=PentestAP

# Optional: override the SSID for the pinning bypass profile
MITMROUTER_PINTEST_SSID=PinBypassAP

# Optional: override default log level (DEBUG, INFO, WARN, ERROR)
MITMROUTER_LOG_LEVEL=INFO

# Optional: override default evidence output root
MITMROUTER_EVIDENCE_DIR=/var/log/mitmrouter/evidence
